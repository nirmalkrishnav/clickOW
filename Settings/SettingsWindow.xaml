<Window x:Class="ClickOw.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClickOw.Settings"
        Title="ClickOw Settings"
        Width="440"
        Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#FF1E1E1E"
        Foreground="#FFEAEAEA"
        FontFamily="Segoe UI"
        FontSize="13">
    <Window.Resources>
        <local:StringToBrushConverter x:Key="BrushConverter" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFEAEAEA" />
            <Setter Property="Margin" Value="0,6" />
        </Style>
        <Style x:Key="Header" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,14,0,6" />
            <Setter Property="Foreground" Value="#FF4FC3F7" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18">
        <StackPanel>
            <TextBlock Text="General" Style="{StaticResource Header}" />
            <CheckBox Content="Enable ClickOw (Ctrl+Alt+C)" IsChecked="{Binding Enabled}" />
            <CheckBox Content="Laser pointer mode (Ctrl+Alt+L)" IsChecked="{Binding LaserMode}" />
            <CheckBox Content="Drag animation" IsChecked="{Binding DragAnimation}" />
            <CheckBox x:Name="StartupCheck" Content="Run at Windows startup" IsChecked="{Binding RunAtStartup}" />

            <TextBlock Text="Colors" Style="{StaticResource Header}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Click" />
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="4" SelectedValuePath="Tag"
                          SelectedValue="{Binding ClickColor}">
                    <ComboBoxItem Content="Default" Tag="{x:Static local:ColorTheme.Default}" />
                    <ComboBoxItem Content="Teal Nebula" Tag="{x:Static local:ColorTheme.TealNebula}" />
                    <ComboBoxItem Content="Coral Blush" Tag="{x:Static local:ColorTheme.CoralBlush}" />
                    <ComboBoxItem Content="Amethyst Haze" Tag="{x:Static local:ColorTheme.AmethystHaze}" />
                    <ComboBoxItem Content="Golden Aurora" Tag="{x:Static local:ColorTheme.GoldenAurora}" />
                    <ComboBoxItem Content="Mint Mirage" Tag="{x:Static local:ColorTheme.MintMirage}" />
                </ComboBox>
                <Border Grid.Row="0" Grid.Column="2" Margin="4" CornerRadius="3"
                        Background="{Binding ClickColorHex, Converter={StaticResource BrushConverter}}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Drag" />
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="4" SelectedValuePath="Tag"
                          SelectedValue="{Binding DragColor}">
                    <ComboBoxItem Content="Default" Tag="{x:Static local:ColorTheme.Default}" />
                    <ComboBoxItem Content="Teal Nebula" Tag="{x:Static local:ColorTheme.TealNebula}" />
                    <ComboBoxItem Content="Coral Blush" Tag="{x:Static local:ColorTheme.CoralBlush}" />
                    <ComboBoxItem Content="Amethyst Haze" Tag="{x:Static local:ColorTheme.AmethystHaze}" />
                    <ComboBoxItem Content="Golden Aurora" Tag="{x:Static local:ColorTheme.GoldenAurora}" />
                    <ComboBoxItem Content="Mint Mirage" Tag="{x:Static local:ColorTheme.MintMirage}" />
                </ComboBox>
                <Border Grid.Row="1" Grid.Column="2" Margin="4" CornerRadius="3"
                        Background="{Binding DragColorHex, Converter={StaticResource BrushConverter}}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Laser" />
                <ComboBox Grid.Row="2" Grid.Column="1" Margin="4" SelectedValuePath="Tag"
                          SelectedValue="{Binding LaserColor}">
                    <ComboBoxItem Content="Default" Tag="{x:Static local:ColorTheme.Default}" />
                    <ComboBoxItem Content="Teal Nebula" Tag="{x:Static local:ColorTheme.TealNebula}" />
                    <ComboBoxItem Content="Coral Blush" Tag="{x:Static local:ColorTheme.CoralBlush}" />
                    <ComboBoxItem Content="Amethyst Haze" Tag="{x:Static local:ColorTheme.AmethystHaze}" />
                    <ComboBoxItem Content="Golden Aurora" Tag="{x:Static local:ColorTheme.GoldenAurora}" />
                    <ComboBoxItem Content="Mint Mirage" Tag="{x:Static local:ColorTheme.MintMirage}" />
                </ComboBox>
                <Border Grid.Row="2" Grid.Column="2" Margin="4" CornerRadius="3"
                        Background="{Binding LaserColorHex, Converter={StaticResource BrushConverter}}" />
            </Grid>

            <TextBlock Text="Sizes" Style="{StaticResource Header}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Click size" />
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="4" SelectedValuePath="Tag"
                          SelectedValue="{Binding ClickSizePreset}">
                    <ComboBoxItem Content="Small" Tag="{x:Static local:SizePreset.Small}" />
                    <ComboBoxItem Content="Medium" Tag="{x:Static local:SizePreset.Medium}" />
                    <ComboBoxItem Content="Large" Tag="{x:Static local:SizePreset.Large}" />
                </ComboBox>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Laser thickness" />
                <ComboBox Grid.Row="1" Grid.Column="1" Margin="4" SelectedValuePath="Tag"
                          SelectedValue="{Binding LaserThicknessPreset}">
                    <ComboBoxItem Content="Small" Tag="{x:Static local:SizePreset.Small}" />
                    <ComboBoxItem Content="Medium" Tag="{x:Static local:SizePreset.Medium}" />
                    <ComboBoxItem Content="Large" Tag="{x:Static local:SizePreset.Large}" />
                </ComboBox>
            </Grid>

            <Button x:Name="CloseButton" Content="Close" Width="90" Height="30" HorizontalAlignment="Right"
                    Margin="0,20,0,0" Click="CloseButton_Click" />
        </StackPanel>
    </ScrollViewer>
</Window>
