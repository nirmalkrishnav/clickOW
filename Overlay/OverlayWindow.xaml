<Window x:Class="ClickOW.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClickOW Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        Focusable="False">
    <Canvas x:Name="RootCanvas" ClipToBounds="False" />
</Window>
